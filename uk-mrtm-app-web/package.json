{
  "name": "uk-mrtm-app-web",
  "version": "0.81.0",
  "engines": {
    "node": "^22"
  },
  "scripts": {
    "postinstall": "node git-version.js && yarn prebuild",
    "ng": "ng",
    "start": "ng serve --serve-path /maritime/",
    "start:govuk-components": "ng build govuk-components --watch --configuration development",
    "test:govuk-components": "jest --config ./projects/govuk-components/jest.config.js",
    "test:govuk-components:watch": "jest --watch --config ./projects/govuk-components/jest.config.js",
    "test:govuk-components:coverage": "jest --coverage --config ./projects/govuk-components/jest.config.js",
    "test:common": "jest --config ./projects/common/jest.config.js",
    "test:frontend": "jest --config ./src/jest.config.js --silent --logHeapUsage --workerIdleMemoryLimit=1GB",
    "test:frontend:watch": "jest --watch --config ./src/jest.config.js",
    "test:frontend:coverage": "jest --coverage --config ./src/jest.config.js",
    "test:app:coverage": "yarn prebuild && yarn run test:frontend:coverage",
    "test:app:watch": "yarn build:govuk-components && yarn run test:frontend:watch",
    "build:govuk-components": "ng build govuk-components",
    "build:mrtm-api": "ng build mrtm-api",
    "build:common": "ng build common",
    "build:common:watch": "ng build common --watch",
    "prebuild": "yarn build:govuk-components && yarn build:mrtm-api && yarn build:common",
    "build": "ng build",
    "prebuild:production": "yarn build:govuk-components && yarn build:mrtm-api && yarn build:common",
    "build:production": "ng build",
    "generate:api": "rimraf projects/mrtm-api/src/lib && openapi-generator-cli generate --openapitools projects/mrtm-api/openapitools.json",
    "postgenerate:api": "rimraf projects/mrtm-api/src/lib/.openapi-generator && ng lint mrtm-api --fix && git add projects/mrtm-api/src/lib && yarn build:mrtm-api",
    "analyze": "ng build --source-map --named-chunks && source-map-explorer dist/uk-mrtm-app-web/browser/*.*.js",
    "lint": "ng lint",
    "release:patch": "yarn version --patch --no-commit-hooks --no-git-tag-version && conventional-changelog -p angular -i CHANGELOG.md -s",
    "release:minor": "yarn version --minor --no-commit-hooks --no-git-tag-version && conventional-changelog -p angular -i CHANGELOG.md -s",
    "release:major": "yarn version --major --no-commit-hooks --no-git-tag-version && conventional-changelog -p angular -i CHANGELOG.md -s",
    "sonar": "sonar-scanner",
    "sonar:local": "sonar-scanner -Dsonar.host.url=http://localhost:9000 -Dsonar.login=admin -Dsonar.password=admin"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.16",
    "@angular/common": "^20.3.16",
    "@angular/compiler": "^20.3.16",
    "@angular/core": "^20.3.16",
    "@angular/forms": "^20.3.16",
    "@angular/platform-browser": "^20.3.16",
    "@angular/platform-browser-dynamic": "^20.3.16",
    "@angular/router": "^20.3.16",
    "@w11k/git-info": "^1.1.2",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "bignumber.js": "^9.3.1",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^5.3.6",
    "google-libphonenumber": "^3.2.44",
    "immer": "^11.1.4",
    "keycloak-angular": "16.1.0",
    "keycloak-js": "25.0.1",
    "papaparse": "^5.5.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^20.0.0",
    "@angular/build": "^20.3.16",
    "@angular/cli": "^20.3.16",
    "@angular/compiler-cli": "^20.3.16",
    "@openapitools/openapi-generator-cli": "^2.29.0",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/gtag.js": "^0.0.19",
    "@types/jest": "^30.0.0",
    "@types/node": "22.19.9",
    "@types/papaparse": "^5.3.16",
    "angular-eslint": "20.7.0",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.5.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "fs-extra": "^10.0.0",
    "git-branch": "^2.0.1",
    "git-describe": "^4.1.0",
    "govuk-frontend": "5.14.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-preset-angular": "^16.0.0",
    "jsdom": "^28.1.0",
    "ng-packagr": "^20.3.2",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "rimraf": "^6.1.3",
    "sonar-scanner": "^3.1.0",
    "source-map-explorer": "^2.5.3",
    "ts-jest": "^29.4.6",
    "ts-node": "~10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.54.0"
  }
}
