<?xml version="1.0" standalone="yes"?>
<xs:schema version="1.0" xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <xs:element name="emissionReportsList" type="emissionReportDetailsListDTO"/>
    <xs:complexType name="emissionReportDetailsListDTO">
        <xs:sequence>
            <xs:element name="emissionReport" type="emissionReportDetailsDTO" minOccurs="1" maxOccurs="1000"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="shipUpdateDTO">
        <xs:sequence>
            <xs:element name="shipImoNumber" minOccurs="1" maxOccurs="1">
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:pattern value="[0-9]{7}"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="name" type="nonEmptyStringMax255" minOccurs="1" maxOccurs="1"/>
            <xs:element name="shipType" type="shipTypeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="grossTonnage" minOccurs="1" maxOccurs="1">
                <xs:simpleType>
                    <xs:restriction base="xs:integer">
                        <xs:minInclusive value="5000"/>
                        <xs:maxInclusive value="999999999"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="flag" type="flagEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="iceClassPolarCode" type="iceClassPolarCodeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="iceClassSurrenderReduction" type="xs:boolean" minOccurs="0" maxOccurs="1"/>
            <xs:element name="allYear" type="xs:boolean" minOccurs="1" maxOccurs="1"/>
            <xs:element name="partialPeriodFromDate" type="xs:date" minOccurs="0" maxOccurs="1"/>
            <xs:element name="partialPeriodToDate" type="xs:date" minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="emissionReportDetailsDTO">
        <xs:complexContent>
            <xs:extension base="shipUpdateDTO">
                <xs:sequence>
                    <xs:element name="company" type="companyUpdateDTO" minOccurs="1" maxOccurs="1"/>
                    <xs:element name="fuelTypes" type="erFuelTypeEmissionFactorSection" minOccurs="1" maxOccurs="1"/>
                    <xs:element name="emissionSources" type="erEmissionSourcesSection" minOccurs="1" maxOccurs="1"/>
                    <xs:element name="monitoringMethods" type="monitoringMethodsSection" minOccurs="1" maxOccurs="1"/>
                    <xs:element name="additionalInformation" type="additionalInformationDTO" minOccurs="1" maxOccurs="1"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="companyUpdateDTO">
        <xs:sequence>
            <xs:element name="nature" type="natureEnum" minOccurs="1" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="erFuelTypeEmissionFactorSection">
        <xs:sequence>
            <xs:element name="fuelTypeEntry" type="fuelTypeEmissionFactorEditDTO" minOccurs="1" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="fuelTypeEmissionFactorEditDTO">
        <xs:sequence>
            <xs:element name="otherFuelType" type="nonEmptyStringMax30" minOccurs="0" maxOccurs="1"/>
            <xs:element name="fuelOriginCode" type="fuelOriginCodeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="fuelTypeCode" type="fuelTypeCodeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="emissionFactors" type="emissionFactorDTO" minOccurs="3" maxOccurs="3"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="emissionFactorDTO">
        <xs:sequence>
            <xs:element name="factorReferenceCode" type="factorReferenceCodeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="ghgCode" type="ghgCodeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="ttwEF" minOccurs="0" maxOccurs="1">
                <xs:simpleType>
                    <xs:restriction base="xs:decimal">
                        <xs:pattern value="\d{1,12}(\.\d+)?"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="erEmissionSourcesSection">
        <xs:sequence>
            <xs:element name="emissionSourceEntry" type="emissionSourceEditDTO" minOccurs="1" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="emissionSourceEditDTO">
        <xs:sequence>
            <xs:element name="name" type="nonEmptyStringMax255" minOccurs="1" maxOccurs="1"/>
            <xs:element name="emissionSourceTypeCode" type="emissionSourceTypeCodeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="emissionSourceClassCode" type="emissionSourceClassCodeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="monitoringMethodCode" type="monitoringMethodCodeEnum" minOccurs="1" maxOccurs="4"/>
            <xs:element name="fuelTypeCodes" type="fuelTypeCodeDTO" minOccurs="1" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="fuelTypeCodeDTO">
        <xs:sequence>
            <xs:element name="fuelTypeCode" type="fuelTypeCodeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="otherFuelType" type="nonEmptyStringMax30" minOccurs="0" maxOccurs="1"/>
            <xs:element name="slipPercentage" minOccurs="0" maxOccurs="1">
                <xs:simpleType>
                    <xs:restriction base="xs:decimal">
                        <xs:minInclusive value="0.000"/>
                        <xs:maxInclusive value="1.000"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="monitoringMethodsSection">
        <xs:sequence>
            <xs:element name="monitoringMethodEntry" type="monitoringMethodEntryDTO" minOccurs="1" maxOccurs="4"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="monitoringMethodEntryDTO">
        <xs:sequence>
            <xs:element name="monitoringMethodCode" type="monitoringMethodCodeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="levelOfUncertaintyTypeCode" type="levelOfUncertaintyTypeCodeEnum" minOccurs="1" maxOccurs="1"/>
            <xs:element name="shipSpecificUncertainty" minOccurs="0" maxOccurs="1">
                <xs:simpleType>
                    <xs:restriction base="xs:decimal">
                        <xs:minInclusive value="0.01"/>
                        <xs:maxInclusive value="100.00"/>
                        <xs:fractionDigits value="2"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="additionalInformationDTO">
        <xs:sequence>
            <xs:element name="exemptionPerVoyageMonitoring" type="xs:boolean" minOccurs="1" maxOccurs="1"/>
            <xs:element name="carbonCaptureReduction" type="xs:boolean" minOccurs="1" maxOccurs="1"/>
            <xs:element name="smallIslandSurrenderReduction" type="xs:boolean" minOccurs="1" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>

    <xs:simpleType name="nonEmptyStringMax30">
        <xs:restriction base="xs:string">
            <xs:minLength value="1"/>
            <xs:maxLength value="30"/>
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="nonEmptyStringMax255">
