{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "strictPropertyInitialization": false,
    "strictNullChecks": false,
    "paths": {
      "@netz/govuk-components": ["dist/govuk-components"],
      "@mrtm/api": ["dist/mrtm-api"],
      "@netz/common/*": ["dist/common/*"],
      "@accessibility/*": ["src/app/accessibility/*"],
      "@accounts/*": ["src/app/accounts/*"],
      "@batch-variations/*": ["src/app/batch-variations/*"],
      "@contact-us/*": ["src/app/contact-us/*"],
      "@cookies/*": ["src/app/cookies/*"],
      "@core/*": ["src/app/core/*"],
      "@error/*": ["src/app/error/*"],
      "@feedback/*": ["src/app/feedback/*"],
      "@forgot-password/*": ["src/app/forgot-password/*"],
      "@guidance/*": ["src/app/guidance/*"],
      "@incorporate-header/*": ["src/app/incorporate-header/*"],
      "@invitation/*": ["src/app/invitation/*"],
      "@landing-page/*": ["src/app/landing-page/*"],
      "@legislation/*": ["src/app/legislation/*"],
      "@mi-reports/*": ["src/app/mi-reports/*"],
      "@notes/*": ["src/app/notes/*"],
      "@privacy-notice/*": ["src/app/privacy-notice/*"],
      "@registration/*": ["src/app/registration/*"],
      "@regulators/*": ["src/app/regulators/*"],
      "@requests/*": ["src/app/requests/*"],
      "@shared/*": ["src/app/shared/*"],
      "@templates/*": ["src/app/templates/*"],
      "@terms-and-conditions/*": ["src/app/terms-and-conditions/*"],
      "@timeout/*": ["src/app/timeout/*"],
      "@timeline/*": ["src/app/timeline/*"],
      "@two-fa/*": ["src/app/two-fa/*"],
      "@version/*": ["src/app/version/*"],
      "@environments/*": ["src/environments/*"],
      "@verification-bodies/*": ["src/app/verification-bodies/*"],
      "@verifiers/*": ["src/app/verifiers/*"]
    },
    "useDefineForClassFields": false
  },
  "exclude": ["**/node_modules/*", "**/coverage/*", "**/dist/*", "**/node/*"],
  "angularCompilerOptions": {
    "fullTemplateTypeCheck": true,
    "strictInjectionParameters": false,
    "strictTemplates": true
  }
}
