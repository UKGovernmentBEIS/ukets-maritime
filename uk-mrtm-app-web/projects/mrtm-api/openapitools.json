{
  "$schema": "../../node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.19.0",
    "generators": {
      "Typescript Angular OAS3 NG20": {
        "generatorName": "typescript-angular",
        "inputSpec": "http://localhost:8085/api/v3/api-docs/Internal%20API",
        "output": "./projects/mrtm-api/src/lib",
        "templateDir": "./projects/mrtm-api/src/assets/templates",
        "ignoreFileOverride": "./projects/mrtm-api/.openapi-generator-ignore",
        "typeMappings": {
          "set": "Array"
        },
        "additionalProperties": {
          "ngVersion": "20.0.0",
          "basePath": "/api",
          "enumPropertyNaming": "UPPERCASE",
          "stringEnums": true
        }
      }
    }
  }
}
