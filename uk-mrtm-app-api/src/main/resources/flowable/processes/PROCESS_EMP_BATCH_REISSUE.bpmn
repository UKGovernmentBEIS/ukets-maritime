  <process id="PROCESS_EMP_BATCH_REISSUE" name="EMP Batch Reissue Process" isExecutable="true">
    <startEvent id="StartEvent_1">
      <outgoing>Flow_1opujsq</outgoing>
    </startEvent>
    <serviceTask id="Activity_0lpi6k4" name="trigger EMP reissue" flowable:async="true" flowable:delegateExpression="#{empBatchTriggerEmpReissueHandlerFlowable}">
      <incoming>Flow_1v0rz0n</incoming>
      <outgoing>Flow_0s0zu9j</outgoing>
      <multiInstanceLoopCharacteristics flowable:collection="accountIds" flowable:elementVariable="accountId" flowable:async="true" />
    </serviceTask>
    <intermediateCatchEvent id="Event_088wx5f" name="EMP batch reissue completed">
      <incoming>Flow_0s0zu9j</incoming>
      <outgoing>Flow_1etgsy1</outgoing>
      <messageEventDefinition flowable:messageExpression="batchEmpReissueCompleted" />
    </intermediateCatchEvent>
    <serviceTask id="Activity_0xd0pff" name="EMP batch reissue completed" flowable:delegateExpression="#{empBatchReissueCompletedHandlerFlowable}">
