        <outgoing>Flow_0hq1tls</outgoing>
        <messageEventDefinition flowable:messageExpression="empReissueCompleted" />
      </startEvent>
      <serviceTask id="Activity_1q4stws" name="EMP reissue completed" flowable:delegateExpression="#{empBatchEmpReissueCompletedHandlerFlowable}">
        <incoming>Flow_0hq1tls</incoming>
        <outgoing>Flow_19tev9h</outgoing>
      </serviceTask>
      <sequenceFlow id="Flow_0hq1tls" sourceRef="Event_1izrf0m" targetRef="Activity_1q4stws" />
      <exclusiveGateway id="Gateway_1sr4tz1" name="batch EMP reissue completed ?" default="Flow_0yobfps">
        <incoming>Flow_19tev9h</incoming>
        <outgoing>Flow_1128ib6</outgoing>
        <outgoing>Flow_0yobfps</outgoing>
      </exclusiveGateway>
      <sequenceFlow id="Flow_19tev9h" sourceRef="Activity_1q4stws" targetRef="Gateway_1sr4tz1" />
