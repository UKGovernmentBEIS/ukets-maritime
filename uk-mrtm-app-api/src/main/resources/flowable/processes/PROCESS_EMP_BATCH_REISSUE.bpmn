  <process id="PROCESS_EMP_BATCH_REISSUE" name="EMP Batch Reissue Process" isExecutable="true">
    <startEvent id="StartEvent_1">
      <outgoing>Flow_1opujsq</outgoing>
    </startEvent>
    <serviceTask id="Activity_0lpi6k4" name="trigger EMP reissue" flowable:delegateExpression="#{empBatchTriggerEmpReissueHandlerFlowable}">
      <incoming>Flow_1v0rz0n</incoming>
      <outgoing>Flow_0s0zu9j</outgoing>
      <multiInstanceLoopCharacteristics flowable:collection="accountIds" flowable:elementVariable="accountId" />
    </serviceTask>
    <serviceTask id="Activity_0xd0pff" name="EMP batch reissue completed" flowable:delegateExpression="#{empBatchReissueCompletedHandlerFlowable}">
      <incoming>Flow_1v51yh4</incoming>
      <outgoing>Flow_1tc33w4</outgoing>
    </serviceTask>
    <sequenceFlow id="Flow_1opujsq" sourceRef="StartEvent_1" targetRef="Activity_131ih32" />
    <sequenceFlow id="Flow_0s0zu9j" sourceRef="Activity_0lpi6k4" targetRef="Event_088wx5f" />
    <sequenceFlow id="Flow_1tc33w4" sourceRef="Activity_0xd0pff" targetRef="Event_05qh1be" />
    <sequenceFlow id="Flow_06vywy1" sourceRef="Activity_131ih32" targetRef="Gateway_1wifmxg" />
    <serviceTask id="Activity_131ih32" name="EMP batch reissue submitted" flowable:delegateExpression="#{empBatchReissueSubmittedHandlerFlowable}"  flowable:async="true">
      <incoming>Flow_1opujsq</incoming>
      <outgoing>Flow_06vywy1</outgoing>
    </serviceTask>
    <endEvent id="Event_05qh1be">
      <incoming>Flow_1tc33w4</incoming>
    </endEvent>
    <sequenceFlow id="Flow_1v51yh4" sourceRef="Activity_1v1o7ti" targetRef="Activity_0xd0pff" />
    <serviceTask id="Activity_1v1o7ti" name="generate report" flowable:async="true" flowable:delegateExpression="#{empBatchReissueGenerateReportHandlerFlowable}">
      <incoming>Flow_18vyfjp</incoming>
      <incoming>Flow_13rkaiq</incoming>
      <outgoing>Flow_1v51yh4</outgoing>
    </serviceTask>
    <exclusiveGateway id="Gateway_1wifmxg" name="check accounts size" default="Flow_18vyfjp">
      <incoming>Flow_06vywy1</incoming>
      <outgoing>Flow_1v0rz0n</outgoing>
      <outgoing>Flow_18vyfjp</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_1v0rz0n" sourceRef="Gateway_1wifmxg" targetRef="Activity_0lpi6k4">
      <conditionExpression xsi:type="tFormalExpression">${accountIds.size() &gt; 0}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_18vyfjp" sourceRef="Gateway_1wifmxg" targetRef="Activity_1v1o7ti" />
    <sequenceFlow id="Flow_00nbuu3" sourceRef="Activity_1kycge2" targetRef="Gateway_0h2ylyc" />
    <serviceTask id="Activity_1kycge2" name="Populate reissues completed number" flowable:delegateExpression="#{empBatchReissuePopulateNumberOfAccountsCompletedHandlerFlowable}">
      <incoming>Flow_1etgsy1</incoming>
      <outgoing>Flow_00nbuu3</outgoing>
    </serviceTask>
    <exclusiveGateway id="Gateway_0h2ylyc" name="all completed">
      <incoming>Flow_00nbuu3</incoming>
      <outgoing>Flow_13rkaiq</outgoing>
      <outgoing>Flow_0sa02ik</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_13rkaiq" sourceRef="Gateway_0h2ylyc" targetRef="Activity_1v1o7ti">
      <conditionExpression xsi:type="tFormalExpression">${batchAccountsCompleted == accountIds.size()}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_0sa02ik" sourceRef="Gateway_0h2ylyc" targetRef="Event_088wx5f">
      <conditionExpression xsi:type="tFormalExpression">${batchAccountsCompleted &lt; accountIds.size()}</conditionExpression>
    </sequenceFlow>
    <intermediateCatchEvent id="Event_088wx5f" name="timer event">
      <incoming>Flow_0s0zu9j</incoming>
      <incoming>Flow_0sa02ik</incoming>
      <outgoing>Flow_1etgsy1</outgoing>
      <timerEventDefinition id="TimerEventDefinition_0fe7m01">
        <timeDuration>PT1S</timeDuration>
      </timerEventDefinition>
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_1etgsy1" sourceRef="Event_088wx5f" targetRef="Activity_1kycge2" />
  </process>
