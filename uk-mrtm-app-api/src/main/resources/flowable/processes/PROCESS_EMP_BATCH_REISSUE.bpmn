      </endEvent>
      <endEvent id="Event_0yhcv20">
        <incoming>Flow_0zinmjw</incoming>
      </endEvent>
      <sequenceFlow id="Flow_1128ib6" name="yes" sourceRef="Gateway_1sr4tz1" targetRef="Activity_0eiaqdl">
        <conditionExpression xsi:type="tFormalExpression">${accountIds.size() == batchAccountsCompleted}</conditionExpression>
      </sequenceFlow>
      <sequenceFlow id="Flow_0yobfps" sourceRef="Gateway_1sr4tz1" targetRef="Event_0v91jk3" />
      <sequenceFlow id="Flow_0zinmjw" sourceRef="Activity_0eiaqdl" targetRef="Event_0yhcv20" />
      <serviceTask id="Activity_0eiaqdl" name="Send batch EMP reissue completed event" flowable:delegateExpression="#{msgThrowHandlerFlowable}">
        <extensionElements>
          <flowable:field name="messageName">
            <flowable:string>batchEmpReissueCompleted</flowable:string>
          </flowable:field>
        </extensionElements>
        <incoming>Flow_1128ib6</incoming>
        <outgoing>Flow_0zinmjw</outgoing>
      </serviceTask>
    </subProcess>
    <sequenceFlow id="Flow_06vywy1" sourceRef="Activity_131ih32" targetRef="Gateway_1wifmxg" />
    <serviceTask id="Activity_131ih32" name="EMP batch reissue submitted" flowable:delegateExpression="#{empBatchReissueSubmittedHandlerFlowable}">
