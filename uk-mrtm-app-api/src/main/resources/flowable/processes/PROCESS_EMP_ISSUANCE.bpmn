  <message id="Message_0ru6fq0" />
  <process id="PROCESS_EMP_ISSUANCE" name="EMP Issuance Process" isExecutable="true">
    <userTask id="EMP_ISSUANCE_APPLICATION_SUBMIT" name="Operator:Submit EMP Issuance Aplication" flowable:formFieldValidation="true" />
    <startEvent id="ApplyForPermitStartEvent" name="Start" flowable:formFieldValidation="true" />
    <sequenceFlow id="Flow_0zyf2mz" sourceRef="EMP_ISSUANCE_APPLICATION_SUBMIT" targetRef="EMP_ISSUANCE_REVIEW" />
    <sequenceFlow id="Flow_0az5ca4" sourceRef="ApplyForPermitStartEvent" targetRef="EMP_ISSUANCE_APPLICATION_SUBMIT" />
    <exclusiveGateway id="Gateway_19o6n11" name="what is the review determination?" />
    <endEvent id="Event_0ol6ie2" />
    <sequenceFlow id="Flow_0r2teah" name="deemed withdrawn" sourceRef="Gateway_19o6n11" targetRef="Activity_0do5bqu">
      <conditionExpression xsi:type="tFormalExpression">${reviewDetermination=='DEEMED_WITHDRAWN'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_1j8ek33" name="approved" sourceRef="Gateway_19o6n11" targetRef="Activity_014ftb6">
      <conditionExpression xsi:type="tFormalExpression">${reviewDetermination=='APPROVED'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_1p48t5z" sourceRef="Activity_014ftb6" targetRef="Activity_11xkdzc" />
    <callActivity id="EMP_ISSUANCE_REVIEW" name="Review EMP Issuance Application" calledElement="APPL_REVIEW" flowable:calledElementType="key" flowable:businessKey="#{businessKey}" flowable:fallbackToDefaultTenant="false">
      <extensionElements>
        <flowable:in source="requestId" target="requestId" />
        <flowable:in source="requestType" target="requestType" />
        <flowable:in source="businessKey" target="businessKey" />
        <flowable:in source="skipPayment" target="skipPayment" />
        <flowable:out source="reviewDetermination" target="reviewDetermination" />
      </extensionElements>
    </callActivity>
    <sequenceFlow id="Flow_1hmzmrq" sourceRef="EMP_ISSUANCE_REVIEW" targetRef="Gateway_19o6n11" />
    <serviceTask id="Activity_014ftb6" name="Handle EMP Issuance Approved" flowable:delegateExpression="#{empIssuanceApprovedHandlerFlowable}" />
    <serviceTask id="Activity_0qgk5of" name="Update Workflow status to APPROVED" flowable:delegateExpression="#{requestUpdateStatusHandlerFlowable}">
      <extensionElements>
        <flowable:field name="requestStatus">
          <flowable:string>APPROVED</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="Flow_1yl4zkz" sourceRef="Activity_0qgk5of" targetRef="Event_0ol6ie2" />
    <serviceTask id="Activity_01z2zx8" name="Add Approved Request Action" flowable:delegateExpression="#{empIssuanceApprovedAddRequestActionHandlerFlowable}" />
    <sequenceFlow id="Flow_06aoewy" sourceRef="Activity_01z2zx8" targetRef="Activity_0mhbb4f" />
    <serviceTask id="Activity_0xyg4pv" name="Add Deemed Withdrawn Request Action" flowable:delegateExpression="#{empIssuanceDeemedWithdrawnAddRequestActionHandlerFlowable}" />
    <sequenceFlow id="Flow_0sgt8le" sourceRef="Activity_0xyg4pv" targetRef="Activity_1h8mfcp" />
    <serviceTask id="Activity_0i0nftz" name="Update Workflow status to WITHDRAWN" flowable:delegateExpression="#{requestUpdateStatusHandlerFlowable}">
      <extensionElements>
        <flowable:field name="requestStatus">
          <flowable:string>WITHDRAWN</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="Flow_0t9cftc" sourceRef="Activity_0i0nftz" targetRef="Event_0ol6ie2" />
    <serviceTask id="Activity_11xkdzc" name="Generate granted documents" flowable:delegateExpression="#{empIssuanceGrantedGenerateDocumentsHandlerFlowable}" />
    <sequenceFlow id="Flow_0glekzj" sourceRef="Activity_11xkdzc" targetRef="Activity_01z2zx8" />
    <serviceTask id="Activity_0do5bqu" name="Generate deemed withdrawn official notice" flowable:delegateExpression="#{empIssuanceDeemedWithdrawnGenerateOfficialNoticeHandlerFlowable}" />
    <sequenceFlow id="Flow_0uznhmg" sourceRef="Activity_0do5bqu" targetRef="Activity_0xyg4pv" />
    <serviceTask id="Activity_0mhbb4f" name="Send Official Notice Email" flowable:delegateExpression="#{empIssuanceSendOfficialNoticeEmailHandlerFlowable}" />
    <sequenceFlow id="Flow_0tu7sxd" sourceRef="Activity_0mhbb4f" targetRef="Activity_0qgk5of" />
    <serviceTask id="Activity_1h8mfcp" name="Send Official Notice Email" flowable:delegateExpression="#{empIssuanceSendOfficialNoticeEmailHandlerFlowable}" />
    <sequenceFlow id="Flow_0sgt2lx" sourceRef="Activity_1h8mfcp" targetRef="Activity_0i0nftz" />
    <textAnnotation id="TextAnnotation_057v3nk">
      <text>requestId</text>
    </textAnnotation>
    <association id="Association_12t8i82" associationDirection="None" sourceRef="ApplyForPermitStartEvent" targetRef="TextAnnotation_057v3nk" />
  </process>
