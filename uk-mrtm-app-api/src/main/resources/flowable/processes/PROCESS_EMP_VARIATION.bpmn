    <exclusiveGateway id="Gateway_1gblt35" name="is peer review required?" />
    <sequenceFlow id="Flow_1y2n251" name="no" sourceRef="Gateway_1gblt35" targetRef="Activity_1npk75e">
      <conditionExpression xsi:type="tFormalExpression">${reviewOutcome!='PEER_REVIEW_REQUIRED'}</conditionExpression>
