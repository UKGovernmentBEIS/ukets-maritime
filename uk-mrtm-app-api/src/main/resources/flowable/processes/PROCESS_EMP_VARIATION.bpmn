    <sequenceFlow id="Flow_05zybuf" name="yes" sourceRef="Gateway_1gblt35" targetRef="Activity_0es14d0">
      <conditionExpression xsi:type="tFormalExpression">${reviewOutcome=='PEER_REVIEW_REQUIRED'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_1tc0wml" name="submitted" sourceRef="Gateway_1p5poiy" targetRef="Gateway_1gblt35" />
    <sequenceFlow id="Flow_1mb9bwg" name="cancelled" sourceRef="Gateway_1p5poiy" targetRef="Activity_0bhmh2k">
