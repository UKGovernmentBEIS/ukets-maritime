  <process id="PROCESS_EMP_VARIATION" name="EMP Variation Process" isExecutable="true">
    <userTask id="EMP_VARIATION_APPLICATION_SUBMIT" name="Operator:&#10;Submit EMP Variation Aplication" flowable:formFieldValidation="true" />
    <startEvent id="Event_18hebpn" name="Start" flowable:formFieldValidation="true" />
    <exclusiveGateway id="Gateway_0plzx0b" name="what is the review determination?" />
    <endEvent id="Event_1435rl5" />
    <callActivity id="Activity_0la8qh3" name="Review EMP Variation Application" calledElement="APPL_REVIEW" flowable:calledElementType="key" flowable:businessKey="#{businessKey}" flowable:fallbackToDefaultTenant="false">
      <extensionElements>
        <flowable:in source="requestId" target="requestId" />
        <flowable:in source="requestType" target="requestType" />
        <flowable:in source="businessKey" target="businessKey" />
        <flowable:in source="skipPayment" target="skipPayment" />
        <flowable:out source="reviewDetermination" target="reviewDetermination" />
      </extensionElements>
    </callActivity>
    <serviceTask id="Activity_15ksia3" name="Update Workflow status to APPROVED" flowable:delegateExpression="#{requestUpdateStatusHandlerFlowable}">
      <extensionElements>
        <flowable:field name="requestStatus">
          <flowable:string>APPROVED</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>
    <serviceTask id="Activity_1yfglar" name="Update Workflow status to REJECTED" flowable:delegateExpression="#{requestUpdateStatusHandlerFlowable}">
      <extensionElements>
        <flowable:field name="requestStatus">
          <flowable:string>REJECTED</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>
    <serviceTask id="Activity_1s8nwkx" name="Update Workflow status to WITHDRAWN" flowable:delegateExpression="#{requestUpdateStatusHandlerFlowable}">
      <extensionElements>
        <flowable:field name="requestStatus">
          <flowable:string>WITHDRAWN</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="Flow_1y7j39m" sourceRef="Event_18hebpn" targetRef="Gateway_1huade3" />
    <sequenceFlow id="Flow_02vp2ek" sourceRef="EMP_VARIATION_APPLICATION_SUBMIT" targetRef="Gateway_0kxajqi" />
    <sequenceFlow id="Flow_1q8pegu" sourceRef="Activity_0la8qh3" targetRef="Gateway_0plzx0b" />
    <sequenceFlow id="Flow_1tx4ddw" name="rejected" sourceRef="Gateway_0plzx0b" targetRef="Activity_0yyq3dc">
      <conditionExpression xsi:type="tFormalExpression">${reviewDetermination=='REJECTED'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_1a0sz6t" name="deemed withdrawn" sourceRef="Gateway_0plzx0b" targetRef="Activity_1lu00d0">
      <conditionExpression xsi:type="tFormalExpression">${reviewDetermination=='DEEMED_WITHDRAWN'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_0sltn69" name="approved" sourceRef="Gateway_0plzx0b" targetRef="Activity_0ttpve7">
      <conditionExpression xsi:type="tFormalExpression">${reviewDetermination=='APPROVED'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_0echj9k" sourceRef="Activity_15ksia3" targetRef="Event_1435rl5" />
    <sequenceFlow id="Flow_08onsm0" sourceRef="Activity_1yfglar" targetRef="Event_1435rl5" />
    <sequenceFlow id="Flow_1g9enj8" sourceRef="Activity_1s8nwkx" targetRef="Event_1435rl5" />
    <exclusiveGateway id="Gateway_1huade3" name="what type of user initiated the flow?" />
    <sequenceFlow id="Flow_178epos" name="operator" sourceRef="Gateway_1huade3" targetRef="EMP_VARIATION_APPLICATION_SUBMIT">
      <conditionExpression xsi:type="tFormalExpression">${requestInitiatorRoleType=='OPERATOR'}</conditionExpression>
    </sequenceFlow>
    <exclusiveGateway id="Gateway_0kxajqi" name="what is the submit outcome?" />
    <sequenceFlow id="Flow_1ul4f0f" name="cancelled" sourceRef="Gateway_0kxajqi" targetRef="Activity_0dc857y">
      <conditionExpression xsi:type="tFormalExpression">${empVariationSubmitOutcome=='CANCELLED'}</conditionExpression>
    </sequenceFlow>
    <endEvent id="Event_0xwu20n">
      <incoming>Flow_1e0fxnx</incoming>
    </endEvent>
    <sequenceFlow id="Flow_1mgsto7" sourceRef="Activity_11lfq4t" targetRef="Event_1435rl5" />
    <serviceTask id="Activity_11lfq4t" name="Update Workflow status to CANCELLED" flowable:delegateExpression="#{requestUpdateStatusHandlerFlowable}">
      <extensionElements>
