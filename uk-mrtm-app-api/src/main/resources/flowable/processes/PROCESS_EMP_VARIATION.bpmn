    <callActivity id="Activity_1j1xob0" name="Payment" calledElement="PAYMENT" flowable:calledElementType="key" flowable:businessKey="#{businessKey}" flowable:inheritVariables="true" flowable:fallbackToDefaultTenant="false">
      <extensionElements>
