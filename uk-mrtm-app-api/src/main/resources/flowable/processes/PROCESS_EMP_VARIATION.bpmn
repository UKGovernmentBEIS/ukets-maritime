      <incoming>Flow_1n11i8a</incoming>
    </userTask>
    <exclusiveGateway id="Gateway_1p5poiy" name="what is the submit outcome?" default="Flow_1tc0wml" />
    <serviceTask id="Activity_0bhmh2k" name="Add cancelled request action" flowable:delegateExpression="#{empVariationAddCancelledRequestActionHandlerFlowable}" />
    <serviceTask id="Activity_1mrf0cx" name="Update Workflow status to CANCELLED" flowable:delegateExpression="#{requestUpdateStatusHandlerFlowable}">
