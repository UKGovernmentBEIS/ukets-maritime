          <flowable:string>CANCELLED</flowable:string>
        </flowable:field>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="Flow_0734yhw" name="regulator" sourceRef="Gateway_1huade3" targetRef="Activity_1snl8xz">
      <conditionExpression xsi:type="tFormalExpression">${requestInitiatorRoleType=='REGULATOR'}</conditionExpression>
    </sequenceFlow>
    <serviceTask id="Activity_0ttpve7" name="Handle EMP&#10;Variation Approved" flowable:delegateExpression="#{empVariationApprovedHandlerFlowable}" />
