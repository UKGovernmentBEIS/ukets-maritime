                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>uk.gov.netz</groupId>
                <artifactId>swagger-coverage-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>report</id>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.liquibase</groupId>
                <artifactId>liquibase-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.hibernate.orm.tooling</groupId>
                <artifactId>hibernate-enhance-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>enhance</id>
                    </execution>
                </executions>
            </plugin>
        </plugins>
